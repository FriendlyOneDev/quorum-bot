TELEGRAM_TOKEN=your_bot_token_here
ADMIN_ID=your_telegram_user_id
DATABASE_URL=postgresql://user:password@host:5432/quorum

ANNOUNCEMENTS_CHAT=@YourGroupUsername
ANNOUNCEMENTS_TOPIC=1061
# Optional second mirror channel — new posts get sent to both when set.
ANNOUNCEMENTS_CHAT_ACADEMY=-100xxxxxxxxxxxx
ANNOUNCEMENTS_TOPIC_ACADEMY=2
REFRESH_INTERVAL_MINUTES=15
